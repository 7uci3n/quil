DISCORD_TOKEN=your_token_here
APP_ID=your_app_id
GUILD_ID=your_guild_id
DEV_GUILD_ID=
# Path to sqlite file (default: ./data/remnant.sqlite)
DB_FILE=./data/remnant.sqlite
# Optional metadata for health/version output
COMMIT_SHA=
NODE_ENV=development
# Permission bypass — comma-separated Discord user IDs. Leave EMPTY in production.
SUPERUSER_IDS=
# Guilds where SUPERUSER_IDS may bypass even in prod — comma-separated guild IDs.
TEST_GUILD_IDS=

# Agent Teams (required only for the Claude Code team workflow / /spawn-team)
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# --- Docker image source (operators: leave commented to use the production image) ---
# Default: ghcr.io/remnantwestmarches/quil:latest
# Override to pull/test a dev build instead:
# QUIL_IMAGE=ghcr.io/7uci3n/quil
# QUIL_TAG=latest