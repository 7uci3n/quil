{
  "name": "quil-remnant-bot",
  "version": "1.0.0",
  "description": "> A modern rewrite of the previous bot for Remnant D&D Discord Server.  \r > Rebuilt on the latest Discord.js with updated configs, typed personality strings, and long-term maintainability in mind.",
  "main": "src/core/bot.ts",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "tsx watch src/core/bot.ts --dev",
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "strings:smoke": "tsx src/scripts/strings-smoke.ts",
    "deploy:dev": "tsx src/scripts/register-commands.ts",
    "deploy:prod": "tsx src/scripts/register-commands.ts --prod",
    "deploy:list:dev": "tsx src/scripts/register-commands.ts --list",
    "deploy:list:prod": "tsx src/scripts/register-commands.ts --list --prod",
    "deploy:clear:global:dev": "tsx src/scripts/register-commands.ts --clear-global",
    "deploy:clear:global:prod": "tsx src/scripts/register-commands.ts --clear-global --prod",
    "prestart": "npm run build",
    "start": "node --enable-source-maps dist/src/core/bot.js",
    "db:init": "tsx src/scripts/init.db.ts",
    "db:migrate": "tsx src/scripts/migrate.db.ts",
    "db:backup": "tsx src/scripts/backup.ts",
    "db:wipe": "tsx src/scripts/wipe.ts",
    "db:seed:me": "tsx src/scripts/seed.me.ts",
    "db:reseed:me": "npm run db:wipe && npm run db:seed:me",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "discord",
    "bot",
    "dnd",
    "d&d",
    "rpg",
    "remnant",
    "dungeon",
    "adventure",
    "dice",
    "tabletop"
  ],
  "author": "Donovan Townes",
  "license": "MIT License",
  "dependencies": {
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "csv-parse": "^6.1.0",
    "discord.js": "^14.27.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
